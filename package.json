{
  "name": "phomu",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "validate-songs": "npx tsx src/utils/validate-song-data.ts",
    "validate-catalog": "npx tsx src/utils/validate-song-catalog.ts",
    "audit-youtube-official": "node scripts/audit-official-youtube-links.js",
    "validate-catalog-strict": "npx tsx src/utils/validate-song-catalog.ts --strict",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e:install": "npx playwright install chromium",
    "test:e2e:install:linux": "npx playwright install-deps chromium",
    "test:e2e:smoke": "npx @playwright/test test e2e/smoke.spec.ts",
    "format:check": "prettier --check .",
    "validate-catalog:report": "npx tsx src/utils/validate-song-catalog.ts --write-report",
    "security:rotate-admin-token": "node scripts/generate-admin-token.js",
    "phase1:acceptance": "npm run typecheck && npm run validate-catalog:report && npm run test:e2e:smoke && node scripts/check-phase1-acceptance.js"
  },
  "dependencies": {
    "@emnapi/core": "^1.9.1",
    "@emnapi/runtime": "^1.9.1",
    "framer-motion": "^12.38.0",
    "html5-qrcode": "^2.3.8",
    "i18next": "^26.0.2",
    "i18next-browser-languagedetector": "^8.2.1",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2",
    "youtube-search-without-api-key": "^2.0.7",
    "ytsr": "^3.8.4"
  }
}
